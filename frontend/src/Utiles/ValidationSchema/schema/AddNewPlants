import { z } from "zod";

// Define the Zod schema for the AddNewPlan form
export const addNewPlanValidationSchema = z.object({
  planName: z.string().min(1, "Plan Name is required"),
  lodgesCamps: z.string().optional(),
  transfers: z.string().optional(),
  activities: z.string().optional(),
  totalPrice: z.string().optional(), // Keeping as string as per your component's state
  planNotes: z.string().optional(),
  // File inputs (planInfoDoc, pdfs) are typically handled outside the primary string/number validation schema
  // as their values in a form submission might be complex File objects or just their names.
  // If you need to validate their presence, you'd usually do it directly in the handleSubmit logic
  // or define a custom Zod schema for them if submitting as part of a multipart/form-data.
});

// Infer the TypeScript type from the schema
export type AddNewPlanFormData = z.infer<typeof addNewPlanValidationSchema>;